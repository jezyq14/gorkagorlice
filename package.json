{
    "name": "gorkagorlice",
    "version": "1.0.0",
    "description": "Strona dla Zespołu Szkół nr 1 w Gorlicach",
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "db:push": "pnpm --filter api db:push",
        "db:generate": "pnpm --filter api db:generate",
        "db:studio": "pnpm --filter api db:studio",
        "format": "prettier --write \"**/*.{ts,js,svelte,json,md}\"",
        "format:check": "prettier --check \"**/*.{ts,js,svelte,json,md}\""
    },
    "keywords": [],
    "author": "jezyq14",
    "license": "ISC",
    "packageManager": "pnpm@10.33.0",
    "dependencies": {
        "@repo/db": "workspace:*",
        "@repo/schema": "workspace:*",
        "turbo": "^2.9.8"
    },
    "devDependencies": {
        "prettier": "^3.8.3",
        "prettier-plugin-svelte": "^3.5.1",
        "prettier-plugin-tailwindcss": "^0.7.4"
    }
}
