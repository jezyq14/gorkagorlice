{
    "baseUrl": ".",
    "paths": {
      "@repo/db": ["../../packages/db/index.ts"],
      "@repo/db/*": ["../../packages/db/*"]
    },
    "target": "ESNext",
    "module": "NodeNext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "outDir": "./dist"
  },
  "exclude": ["node_modules"]
}
